class Solution {
    public int[] separateDigits(int[] nums) {
        List <Integer> ans = new ArrayList<>();
        for(int n : nums){
            String s = String.valueOf(n);
            for(int i = 0; i < s.length(); i++){
               ans.add(s.charAt(i) - '0');
            }
        }
        int [] res = new int [ans.size()];
        for(int i = 0; i<ans.size(); i++){
          res[i] = ans.get(i);
        }
        return res;
    }
}
